{
  "name": "react-simple-modal",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/react-simple-modal.umd.js",
  "module": "dist/react-simple-modal.es.js",
  "types": "dist/react-simple-modal.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-simple-modal.es.js",
